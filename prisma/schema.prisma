generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  serviceType String?
  comment     String?
  status      String   @default("new") // new, contacted, qualified, lost
  source      String   @default("website")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  notes       String?
  tags        String?  // JSON array of tag strings, e.g. '["VIP","Покупатель"]'
  client      Client?
  tasks       Task[]
}

model Client {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  telegram        String?
  notes           String?
  tags            String?  // JSON array
  telegramHandle  String?  // @username without @
  maxId           String?  // Max user ID
  source          String?  // where client came from
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deals           Deal[]
  leadId          String?  @unique
  lead            Lead?    @relation(fields: [leadId], references: [id])
}

model Deal {
  id          String   @id @default(cuid())
  title       String
  stage       String   @default("new") // new, showing, negotiation, contract, closed_won, closed_lost
  value       Float?
  commission  Float?  // calculated commission
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  closedAt    DateTime?
  tasks       Task[]
}

model Property {
  id          String   @id @default(cuid())
  title       String
  address     String?
  type        String?  // apartment, house, commercial, land
  rooms       Int?
  area        Float?
  price       Float?
  status      String   @default("available") // available, reserved, sold
  cianUrl     String?
  description String?
  imageUrls   String?  // JSON array
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deals       Deal[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending") // pending, in_progress, completed
  priority    String   @default("medium") // low, medium, high
  dueDate     DateTime?
  clientName  String?
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?
}

model Setting {
  key         String   @id
  value       String
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  details     String?
  createdAt   DateTime @default(now())
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String
  category  String   @default("general") // greeting, showing, followup, congrats, general
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Case {
  id        String   @id @default(cuid())
  title     String
  text      String
  result    String?  // e.g. "Продано за 12 дней", "Экономия 300 000 ₽"
  isHidden  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  name      String
  text      String
  rating    Int      @default(5) // 1-5
  source    String?  // cian, google, yandex, manual
  isHidden  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}